# Normalize line endings to LF for all text files in the repo
* text=auto eol=lf

# Explicitly treat common source/config files as LF text
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.css text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sql text eol=lf
Dockerfile text eol=lf
.env.example text eol=lf

# Binary files (never normalize)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
