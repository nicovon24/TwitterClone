# PostgreSQL connection string
DATABASE_URL=postgres://postgres:postgres@postgres:5432/clontwitter

# JWT access token secret (used to sign 15-minute access tokens)
JWT_SECRET=change-me-access-secret

# JWT refresh token secret (used to sign 30-day refresh tokens)
REFRESH_TOKEN_SECRET=change-me-refresh-secret

# Backend port (default 4000)
PORT=4000

# Node environment: development | test | production
NODE_ENV=development

# Backend API URL consumed by the Next.js frontend at build time
NEXT_PUBLIC_API_URL=http://localhost:4000
